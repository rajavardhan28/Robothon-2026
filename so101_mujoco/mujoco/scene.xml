<mujoco model="scene">
    <include file="so101_new_calib.xml" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />
        <global azimuth="160" elevation="-20" />
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
            height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
            rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
            reflectance="0.2" />
        <material name="table_wood" rgba="0.58 0.39 0.24 1" />
        <material name="table_metal" rgba="0.28 0.28 0.28 1" />
        <material name="red_object" rgba="0.9 0.15 0.15 1" />
        <material name="blue_object" rgba="0.15 0.3 0.9 1" />
    </asset>

    <worldbody>
        <light pos="0 0 3.5" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" />

        <!-- Workbench table: surface at z=0, robot base sits on top -->
        <body name="workbench" pos="0 0 0">
            <geom name="table_top" type="box" pos="0 0 -0.025" size="0.6 0.4 0.025"
                  material="table_wood" contype="1" conaffinity="1" />
            <geom name="leg_fl" type="box" pos=" 0.55  0.35 -0.4" size="0.035 0.035 0.375"
                  material="table_metal" />
            <geom name="leg_fr" type="box" pos=" 0.55 -0.35 -0.4" size="0.035 0.035 0.375"
                  material="table_metal" />
            <geom name="leg_rl" type="box" pos="-0.55  0.35 -0.4" size="0.035 0.035 0.375"
                  material="table_metal" />
            <geom name="leg_rr" type="box" pos="-0.55 -0.35 -0.4" size="0.035 0.035 0.375"
                  material="table_metal" />
        </body>

        <!-- Graspable red box: 3.5x3.5x5 cm, ~25 cm in front of robot -->
        <body name="red_box" pos="0.25 0.0 0.025">
            <freejoint name="red_box_joint" />
            <inertial pos="0 0 0" mass="0.05" diaginertia="3.54e-05 3.54e-05 2.04e-05" />
            <geom name="red_box_geom" type="box" size="0.0175 0.0175 0.025"
                  material="red_object" friction="0.8 0.005 0.0001" />
        </body>

        <!-- Graspable blue cylinder: r=1.8 cm, h=5 cm, offset 12 cm to side -->
        <body name="blue_cylinder" pos="0.25 0.12 0.025">
            <freejoint name="blue_cyl_joint" />
            <inertial pos="0 0 0" mass="0.05" diaginertia="3.70e-05 3.70e-05 8.10e-06" />
            <geom name="blue_cyl_geom" type="cylinder" size="0.018 0.025"
                  material="blue_object" friction="0.8 0.005 0.0001" />
        </body>
    </worldbody>
</mujoco>